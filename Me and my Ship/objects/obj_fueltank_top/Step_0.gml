scr_Rotation()
if (global.fule_top >= 80){
	image_index = 0
} 
else if(80 >global.fule_top >= 60){
	image_index = 1
} 
else if(60 >global.fule_top >= 40){
	image_index = 2
} 
else if(40 >global.fule_top >= 20){
	image_index = 3
} 
else if(20 >global.fule_top > 0){
	image_index = 4
} 
else if(0>= global.fule_top){
	image_index = 5
} 