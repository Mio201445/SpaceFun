scr_Rotation()
if (global.fule_botom >= 80){
	image_index = 0
} 
else if(80 >global.fule_botom >= 60){
	image_index = 1
} 
else if(60 >global.fule_botom >= 40){
	image_index = 2
} 
else if(40 >global.fule_botom >= 20){
	image_index = 3
} 
else if(20 >global.fule_botom > 0){
	image_index = 4
} 
else if(0>= global.fule_botom ){
	image_index = 5
} 